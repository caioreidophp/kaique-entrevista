APP_NAME=Kaique
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://app.kaiquetransportes.com.br
APP_FORCE_HTTPS=true

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=cache
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kaique_entrevista
DB_USERNAME=kaique_user
DB_PASSWORD=trocar_senha_forte

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=app.kaiquetransportes.com.br
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.seuprovedor.com
MAIL_PORT=587
MAIL_USERNAME=seu_usuario
MAIL_PASSWORD=sua_senha
MAIL_FROM_ADDRESS=nao-responda@kaiquetransportes.com.br
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=app.kaiquetransportes.com.br

TRANSPORT_FEATURE_SECURITY_HEADERS=true
TRANSPORT_FEATURE_SENSITIVE_AUDIT=true

BOB_ENABLED=false

VITE_APP_NAME="${APP_NAME}"
VITE_BOB_ENABLED=false
